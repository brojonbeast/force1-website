---
import Base from '../layouts/Base.astro';
---
<Base title="Contact" description="Get in touch with Force1 Training Facility. Call (409) 526-6108 or email join@force1trainingfacility.com.">
  <div class="page-hero" style="background-image:url('/images/dumbbells.webp')">
    <div class="container">
      <span class="kicker">Contact</span>
      <h1>Get In <span class="accent">Touch</span></h1>
    </div>
  </div>

  <section>
    <div class="container split" style="align-items:start;">
      <div>
        <h2>Reach <span class="accent">Us</span></h2>
        <div class="grid" style="margin-top:2rem; gap:1rem;">
          <div class="card">
            <h3>Phone</h3>
            <p><a href="tel:+14095266108">(409) 526-6108</a></p>
          </div>
          <div class="card">
            <h3>Email</h3>
            <p><a href="mailto:join@force1trainingfacility.com">join@force1trainingfacility.com</a></p>
          </div>
          <div class="card">
            <h3>Hours</h3>
            <p>24/7 access for members<br />Staffed 4am&ndash;12am, 7 days a week</p>
          </div>
          <div class="card">
            <h3>Location</h3>
            <p>Coming soon — follow us for the announcement.</p>
          </div>
        </div>
      </div>
      <div>
        <h2>Send A <span class="accent">Message</span></h2>
        <form class="form" id="contact-form" onsubmit="return false" style="margin-top:2rem;">
          <div>
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required />
          </div>
          <div>
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required />
          </div>
          <div>
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" required></textarea>
          </div>
          <button type="submit" class="btn">Send Message</button>
        </form>
      </div>
    </div>
  </section>

</Base>
