---
import Base from '../layouts/Base.astro';
---
<Base title="About Us" description="Force1 Training Facility — a warehouse-style strength and conditioning gym built for serious training.">
  <div class="page-hero" style="background-image:url('/images/hero.webp')">
    <div class="container">
      <span class="kicker">About Us</span>
      <h1>Why We <span class="accent">Built This</span></h1>
    </div>
  </div>

  <section>
    <div class="container split">
      <div>
        <span class="kicker">Our Story</span>
        <h2>No Frills. <span class="accent">All Force.</span></h2>
        <p style="margin:1.25rem 0;">
          Force1 was built for the people big-box gyms forgot: the ones who chalk up,
          load plates, and measure progress in pounds on the bar. We took a warehouse,
          filled it with the best strength equipment made — Hammer Strength, Rogue,
          Arsenal, Rogers Pendulum, Nautilus, and more — and kept the doors open 24/7.
        </p>
        <p>
          There's no juice bar and no lounge. What you get instead is space to train,
          iron that lasts, and a community of people pulling in the same direction:
          forward.
        </p>
      </div>
      <img src="/images/squat.webp" alt="Heavy squat inside the Force1 power rack row" loading="lazy" />
    </div>
  </section>

  <div class="stats">
    <div class="container">
      <div class="stat"><strong>24/7</strong><span>Member Access</span></div>
      <div class="stat"><strong>4am&ndash;12am</strong><span>Staffed Every Day</span></div>
      <div class="stat"><strong>10+</strong><span>Equipment Brands</span></div>
    </div>
  </div>

  <section>
    <div class="container">
      <span class="kicker">What We Stand For</span>
      <h2>The Force1 <span class="accent">Standard</span></h2>
      <div class="grid grid-3" style="margin-top:2.5rem;">
        <div class="card">
          <h3>Effort First</h3>
          <p>Everyone starts somewhere. What matters here isn't how much you lift — it's that you show up and work.</p>
        </div>
        <div class="card">
          <h3>Respect The Iron</h3>
          <p>Rack your plates, share the platform, and treat the equipment like it's yours — because it is.</p>
        </div>
        <div class="card">
          <h3>Community Of Strength</h3>
          <p>Spot a stranger, cheer a PR, and push the person next to you. Strong people make each other stronger.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="cta-band" style="background-image:url('/images/facility-wide.webp')">
    <div class="container">
      <h2>Come Meet Us <span class="accent">In Person</span></h2>
      <p>The best way to understand Force1 is to train here. Your first week is on us.</p>
      <a href="/free-pass/" class="btn">Get Your Free 7 Day Pass</a>
    </div>
  </div>
</Base>
