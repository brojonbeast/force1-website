---
import Base from '../layouts/Base.astro';
---
<Base title="Personal Training" description="One-on-one strength and conditioning coaching at Force1 Training Facility.">
  <div class="page-hero" style="background-image:url('/images/training.webp')">
    <div class="container">
      <span class="kicker">Personal Training</span>
      <h1>Coaching That <span class="accent">Moves The Bar</span></h1>
    </div>
  </div>

  <section>
    <div class="container split">
      <div>
        <span class="kicker">1-On-1 Coaching</span>
        <h2>Stop Guessing. <span class="accent">Start Progressing.</span></h2>
        <p style="margin:1.25rem 0;">
          Whether you're brand new to the barbell or chasing a competition total, our coaches
          build programs around you — your goals, your schedule, your starting point. Every
          session is programmed, tracked, and adjusted so you keep moving forward.
        </p>
        <p style="margin-bottom:2rem;">
          Training at Force1 means access to equipment most coaches only dream of programming
          with — from Rogers Pendulum and Hammer Strength to a full Rogue strength setup.
        </p>
        <a href="/contact/" class="btn">Book A Consultation</a>
      </div>
      <img src="/images/training.webp" alt="Force1 coach guiding an athlete through a deadlift" loading="lazy" />
    </div>
  </section>

  <section style="padding-top:0;">
    <div class="container">
      <div class="grid grid-3">
        <div class="card">
          <h3>Strength</h3>
          <p>Squat, bench, deadlift, and overhead work programmed with progressive overload. Get measurably stronger, month after month.</p>
        </div>
        <div class="card">
          <h3>Conditioning</h3>
          <p>Sled work, carries, and engine-building sessions that make you harder to kill — on the field, on the platform, or in life.</p>
        </div>
        <div class="card">
          <h3>Body Composition</h3>
          <p>Training and accountability structured around building muscle and dropping fat — without gimmicks or crash protocols.</p>
        </div>
      </div>
      <p style="text-align:center; margin-top:3rem;">
        Ready to start? Call <a href="tel:+14095266108" class="accent">(409) 526-6108</a> or
        <a href="/contact/" class="accent">send us a message</a> to set up your first session.
      </p>
    </div>
  </section>
</Base>
