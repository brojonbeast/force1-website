---
import Base from '../layouts/Base.astro';
---
<Base title="Memberships" description="Force1 Training Facility membership options — 24/7 access to a warehouse-style strength and conditioning gym.">
  <div class="page-hero" style="background-image:url('/images/machines.webp')">
    <div class="container">
      <span class="kicker">Memberships</span>
      <h1>Pick Your <span class="accent">Commitment</span></h1>
    </div>
  </div>

  <section>
    <div class="container">
      <!-- TODO: Replace placeholder tiers/prices with final pricing -->
      <div class="grid grid-3">
        <div class="price-card">
          <h3>Monthly</h3>
          <div class="price">$XX<small>/mo</small></div>
          <ul>
            <li>24/7 facility access</li>
            <li>Full equipment floor</li>
            <li>No long-term contract</li>
          </ul>
          <a href="/free-pass/" class="btn btn--ghost">Start With A Free Week</a>
        </div>
        <div class="price-card featured">
          <h3>Annual</h3>
          <div class="price">$XX<small>/mo</small></div>
          <ul>
            <li>24/7 facility access</li>
            <li>Full equipment floor</li>
            <li>Best monthly rate</li>
            <li>Locked-in pricing</li>
          </ul>
          <a href="/free-pass/" class="btn">Start With A Free Week</a>
        </div>
        <div class="price-card">
          <h3>Day Pass</h3>
          <div class="price">$XX<small>/day</small></div>
          <ul>
            <li>Full-day facility access</li>
            <li>Perfect for travelers</li>
            <li>Staffed hours: 4am&ndash;12am</li>
          </ul>
          <a href="/contact/" class="btn btn--ghost">Contact Us</a>
        </div>
      </div>
      <p style="text-align:center; margin-top:3rem;">
        Questions about memberships? Call <a href="tel:+14095266108" class="accent">(409) 526-6108</a>
        or email <a href="mailto:join@force1trainingfacility.com" class="accent">join@force1trainingfacility.com</a>.
      </p>
    </div>
  </section>

  <div class="cta-band" style="background-image:url('/images/hero.webp')">
    <div class="container">
      <h2>Not Sure Yet? <span class="accent">Train Free For A Week.</span></h2>
      <p>Every membership starts the same way — walking through the door. Try us free for 7 days.</p>
      <a href="/free-pass/" class="btn">Get The Free Pass</a>
    </div>
  </div>
</Base>
