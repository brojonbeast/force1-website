---
import Base from '../layouts/Base.astro';
---
<Base title="Home">
  <!-- HERO -->
  <div class="hero" style="background-image:url('/images/hero.webp')">
    <div class="container">
      <span class="kicker">Warehouse Strength &amp; Conditioning</span>
      <h1>Train With <span class="accent">Force.</span></h1>
      <p>
        Force1 is a no-frills, warehouse-style training facility built for people who take
        strength seriously. Elite equipment, 24/7 access, and an atmosphere that pushes you
        to work harder than you did yesterday.
      </p>
      <div class="hero-actions">
        <a href="/free-pass/" class="btn">Get Your Free 7 Day Pass</a>
        <a href="/memberships/" class="btn btn--ghost">View Memberships</a>
      </div>
    </div>
  </div>

  <!-- STATS -->
  <div class="stats">
    <div class="container">
      <div class="stat"><strong>24/7</strong><span>Member Access</span></div>
      <div class="stat"><strong>4am&ndash;12am</strong><span>Staffed Daily</span></div>
      <div class="stat"><strong>10+</strong><span>Elite Equipment Brands</span></div>
      <div class="stat"><strong>7 Days</strong><span>Free Trial Pass</span></div>
    </div>
  </div>

  <!-- WHY FORCE1 -->
  <section>
    <div class="container">
      <span class="kicker">Why Force1</span>
      <h2>Built Different. <span class="accent">On Purpose.</span></h2>
      <div class="grid grid-3" style="margin-top:2.5rem;">
        <div class="card">
          <h3>Serious Iron</h3>
          <p>Hammer Strength, Rogue, Arsenal, Nautilus, Rogers Pendulum and more. Plate-loaded, purpose-built equipment you won't find at a big-box gym.</p>
        </div>
        <div class="card">
          <h3>24/7 Access</h3>
          <p>Your schedule doesn't stop at 9pm, and neither do we. Members train any hour, any day. Staffed 4am to midnight, every day of the week.</p>
        </div>
        <div class="card">
          <h3>Real Atmosphere</h3>
          <p>Chalk is welcome. Effort is expected. A warehouse environment engineered for strength and conditioning — not for lounging.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- EQUIPMENT BRANDS -->
  <div class="brands">
    <div class="container">
      <h3 style="text-align:center; margin-bottom:1.5rem;">Equipment You'll <span class="accent">Actually Want</span> To Train On</h3>
      <ul class="brand-list">
        <li>Hammer Strength</li>
        <li>Cybex</li>
        <li>Body Masters</li>
        <li>MegaMass</li>
        <li>Rogue</li>
        <li>Arsenal</li>
        <li>TSS</li>
        <li>Nautilus</li>
        <li>Rogers Pendulum</li>
        <li>Flex Fitness</li>
      </ul>
    </div>
  </div>

  <!-- FACILITY SPLIT -->
  <section>
    <div class="container split">
      <img src="/images/facility-wide.webp" alt="Inside the Force1 warehouse training floor" loading="lazy" />
      <div>
        <span class="kicker">The Facility</span>
        <h2>A Warehouse Full Of <span class="accent">Tools, Not Toys</span></h2>
        <p style="margin:1.25rem 0 2rem;">
          Power racks, plate-loaded machines, heavy dumbbells, turf for sled work, and
          conditioning space — all under one industrial roof. Whether you're chasing a
          bigger total, a faster forty, or just the best shape of your life, the equipment
          here won't be your limiting factor.
        </p>
        <a href="/gallery/" class="btn btn--ghost">See The Gallery</a>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <div class="cta-band" style="background-image:url('/images/chalk.webp')">
    <div class="container">
      <h2>Try Force1 <span class="accent">Free For 7 Days</span></h2>
      <p>No pressure, no gimmicks. Come train with us for a full week and see if you belong here.</p>
      <a href="/free-pass/" class="btn">Claim Your Free Pass</a>
    </div>
  </div>
</Base>
